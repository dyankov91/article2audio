#!/usr/bin/env python3
"""
a2pod — Convert any article URL to an audiobook.

Usage:
    a2pod <url> [--voice VOICE] [--speed SPEED] [--no-upload]
    a2pod --file <path> [--title TITLE] [--voice VOICE] [--speed SPEED]
"""

import argparse
import sys
import textwrap
from pathlib import Path

# Add lib to path
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

from errors import PipelineError
from pipeline import run_pipeline
from tts import DEFAULT_VOICE, DEFAULT_SPEED, DEFAULT_WORKERS
from llm import DEFAULT_MODEL
from publisher import is_aws_configured, find_episode, delete_episode, delete_all_episodes, list_episodes


def _print_progress(msg: str) -> None:
    """Print progress messages in the same style as the original CLI."""
    print(f"  {msg}")


def main():
    parser = argparse.ArgumentParser(
        description="Convert articles to audiobooks and publish to podcast feed",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Examples:
              a2pod https://example.com/article
              a2pod https://example.com/article --voice am_michael
              a2pod --file article.txt --title "My Article"
              a2pod https://example.com/article --no-upload
        """),
    )
    parser.add_argument("url", nargs="?", help="Article URL to convert")
    parser.add_argument("--file", "-f", help="Local text file instead of URL")
    parser.add_argument("--title", "-t", help="Override article title")
    parser.add_argument("--voice", "-v", default=DEFAULT_VOICE,
                        help=f"TTS voice (default: {DEFAULT_VOICE})")
    parser.add_argument("--speed", "-s", type=float, default=DEFAULT_SPEED,
                        help=f"Speech speed (default: {DEFAULT_SPEED})")
    parser.add_argument("--no-upload", action="store_true",
                        help="Skip S3 upload and podcast feed update")
    parser.add_argument("--output", "-o", help="Custom output path")
    parser.add_argument("--model", "-m", default=DEFAULT_MODEL,
                        help=f"LLM model (default: {DEFAULT_MODEL}, based on configured provider)")
    parser.add_argument("--no-summary", action="store_true",
                        help="Skip episode summary generation")
    parser.add_argument("--workers", "-w", type=int, default=DEFAULT_WORKERS,
                        help=f"Parallel TTS workers (default: {DEFAULT_WORKERS})")
    parser.add_argument("--no-intro", action="store_true",
                        help="Skip episode intro (jingle + spoken title)")
    parser.add_argument("--force", action="store_true",
                        help="Reprocess even if already in the podcast feed")
    parser.add_argument("--delete", metavar="QUERY",
                        help="Delete episode matching title or URL")
    parser.add_argument("--delete-all", action="store_true",
                        help="Delete all episodes from the feed and S3")

    args = parser.parse_args()

    if args.delete:
        episode = find_episode(args.delete)
        if not episode:
            print(f"  No episode found matching: {args.delete}")
            sys.exit(1)
        print(f"  Deleting \"{episode['title']}\"...")
        try:
            result = delete_episode(args.delete)
            print(f"  Deleted \"{result['title']}\" ({result['files_deleted']} file(s) removed).")
        except PipelineError as e:
            print(f"\n  Error: {e}")
            sys.exit(1)
        return

    if args.delete_all:
        episodes = list_episodes()
        if not episodes:
            print("  No episodes in the feed.")
            return
        print(f"  This will delete {len(episodes)} episode(s) and all files from S3.")
        confirm = input("  Type 'yes delete everything' to confirm: ").strip()
        if confirm != "yes delete everything":
            print("  Cancelled.")
            return
        result = delete_all_episodes()
        print(f"  Deleted {result['episodes_deleted']} episode(s), "
              f"{result['files_deleted']} file(s) removed from S3.")
        return

    if not args.url and not args.file:
        parser.print_help()
        sys.exit(1)

    if not is_aws_configured() and not args.no_upload:
        print("  AWS not configured — saving locally only.\n")

    try:
        result = run_pipeline(
            url=args.url,
            file_path=args.file,
            title=args.title,
            voice=args.voice,
            speed=args.speed,
            model=args.model,
            no_upload=args.no_upload,
            no_summary=args.no_summary,
            no_intro=args.no_intro,
            output=args.output,
            force=args.force,
            workers=args.workers,
            on_progress=_print_progress,
        )
    except PipelineError as e:
        print(f"\n  ❌ {e}")
        sys.exit(1)

    print()


if __name__ == "__main__":
    main()
